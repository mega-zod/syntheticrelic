FROM node:22-bookworm-slim AS deps
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci

FROM node:22-bookworm-slim AS build
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY . .
ARG NEXT_PUBLIC_RELIC_API_URL=https://api.syntheticrelic.dev
ARG NEXT_PUBLIC_RELIC_WS_URL=wss://api.syntheticrelic.dev/ws/arena
ENV NEXT_PUBLIC_RELIC_API_URL=$NEXT_PUBLIC_RELIC_API_URL
ENV NEXT_PUBLIC_RELIC_WS_URL=$NEXT_PUBLIC_RELIC_WS_URL
RUN npm run build:next
RUN npm prune --omit=dev

FROM node:22-bookworm-slim AS runtime
WORKDIR /app
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
COPY --from=build /app/package.json /app/package-lock.json ./
COPY --from=build /app/node_modules ./node_modules
COPY --from=build /app/apps/web ./apps/web
COPY --from=build /app/src ./src
EXPOSE 3000
CMD ["npx", "next", "start", "apps/web", "-H", "0.0.0.0", "-p", "3000"]
