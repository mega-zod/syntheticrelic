# Synthetic Relic production environment

SYNTHETIC_RELIC_ENV=production
SYNTHETIC_RELIC_ADMIN_TOKEN=replace-with-a-long-random-secret
SYNTHETIC_RELIC_ORIGINS=https://syntheticrelic.dev
SYNTHETIC_RELIC_DB=/data/synthetic-relic/relic.db
SYNTHETIC_RELIC_ALLOW_INSECURE_ADMIN=false
SYNTHETIC_RELIC_ENFORCE_HTTPS=true
SYNTHETIC_RELIC_MAX_BODY_BYTES=1000000
SYNTHETIC_RELIC_RATE_LIMIT_WINDOW_SECONDS=60
SYNTHETIC_RELIC_RATE_LIMIT_MAX_REQUESTS=180
SYNTHETIC_RELIC_ADMIN_SESSION_TTL_SECONDS=3600
SYNTHETIC_RELIC_AGENT_CHALLENGE_TTL_SECONDS=300
SYNTHETIC_RELIC_REQUIRE_AGENT_CHALLENGE=true
SYNTHETIC_RELIC_BACKUP_INTERVAL_MINUTES=360

# Frontend build/runtime API targets
NEXT_PUBLIC_RELIC_API_URL=https://api.syntheticrelic.dev
NEXT_PUBLIC_RELIC_WS_URL=wss://api.syntheticrelic.dev/ws/arena
VITE_RELIC_API_URL=https://api.syntheticrelic.dev
VITE_RELIC_WS_URL=wss://api.syntheticrelic.dev/ws/arena
